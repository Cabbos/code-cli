{
  "name": "code-cli",
  "version": "0.1.0",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "code-cli": "dist/index.js",
    "ccode": "dist/bin/ccode.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc -p tsconfig.json --noEmit",
    "dev": "ts-node src/index.ts",
    "start": "node dist/index.js",
    "test": "npm run test:unit && npm run build && npm run eval:restore && npm run eval && npm run eval:replay:fixtures",
    "test:unit": "vitest run",
    "test:watch": "vitest",
    "eval": "ts-node src/eval/run.ts",
    "eval:live": "ts-node src/eval/live.ts",
    "eval:replay": "ts-node src/eval/replay.ts",
    "eval:trace": "ts-node src/eval/trace.ts",
    "eval:restore": "node scripts/eval-restore.js",
    "eval:replay:fixtures": "npm run eval:replay -- --trace evals/fixtures/replay-basic.jsonl --workspace evals/replay-workspace --ignore-output && npm run eval:replay -- --trace evals/fixtures/replay-strict.jsonl --workspace evals/replay-workspace"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "A CLI starter project",
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^11.1.0",
    "ignore": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@vitest/ui": "^4.1.2",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
