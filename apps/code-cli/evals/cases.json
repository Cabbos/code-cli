{
  "cases": [
    {
      "name": "echo",
      "prompt": "hello",
      "expectContains": "mock:hello"
    },
    {
      "name": "tool_list_files",
      "prompt": "tool:fs.listFiles {\"dir\":\"src\",\"recursive\":false}",
      "expectContains": "mock:tool_result:fs.listFiles"
    },
    {
      "name": "tool_search_rg",
      "prompt": "tool:search.rg {\"pattern\":\"runAgentTurn\",\"dir\":\"src/agent\",\"maxResults\":5}",
      "expectContains": "runAgentTurn"
    },
    {
      "name": "tool_apply_patch_missing",
      "prompt": "tool:fs.applyPatch {\"path\":\"evals/replay-workspace/__missing__.txt\",\"patch\":\"@@ -1 +1 @@\\n-a\\n+b\\n\"}",
      "expectContains": "File not found"
    },
    {
      "name": "tool_git_diff",
      "prompt": "tool:git.diff {\"contextLines\":1,\"maxBytes\":5000}",
      "expectContains": "\"isRepo\""
    },
    {
      "name": "tool_git_status",
      "prompt": "tool:git.status {\"maxBytes\":5000}",
      "expectContains": "\"entries\""
    },
    {
      "name": "tool_invalid_input_type",
      "prompt": "tool:git.status {\"paths\":\"not-an-array\"}",
      "expectContains": "Invalid tool input"
    },
    {
      "name": "tool_invalid_input_extra_field",
      "prompt": "tool:git.status {\"maxBytes\":5000,\"nope\":true}",
      "expectContains": "is not allowed"
    },
    {
      "name": "tool_batchRead_multiple",
      "prompt": "tool:fs.batchRead {\"paths\":[\"package.json\",\"README.md\"]}",
      "expectContains": "code-cli"
    },
    {
      "name": "tool_batchRead_missing",
      "prompt": "tool:fs.batchRead {\"paths\":[\"evals/replay-workspace/__nonexistent__.txt\"]}",
      "expectContains": "error"
    },
    {
      "name": "tool_batchWrite_atomic_success",
      "prompt": "tool:fs.batchWrite {\"entries\":[{\"path\":\"evals/replay-workspace/__test1__.txt\",\"content\":\"hello\"},{\"path\":\"evals/replay-workspace/__test2__.txt\",\"content\":\"world\"}]}",
      "expectContains": "\"written\""
    },
    {
      "name": "tool_rename_single",
      "prompt": "tool:fs.rename {\"from\":\"evals/replay-workspace/hello.txt\",\"to\":\"evals/replay-workspace/hello_renamed.txt\"}",
      "expectContains": "\"renamed\""
    },
    {
      "name": "tool_delete_file",
      "prompt": "tool:fs.delete {\"path\":\"evals/replay-workspace/hello_renamed.txt\"}",
      "expectContains": "\"deleted\""
    },
    {
      "name": "tool_copy_file",
      "prompt": "tool:fs.copy {\"from\":\"evals/replay-workspace/nested/note.md\",\"to\":\"evals/replay-workspace/note_copy.md\"}",
      "expectContains": "\"copied\""
    },
    {
      "name": "tool_ast_listSymbols",
      "prompt": "tool:ast.listSymbols {\"path\":\"src/tools/defaultRegistry.ts\"}",
      "expectContains": "FunctionDeclaration"
    },
    {
      "name": "tool_ast_renameSymbol",
      "prompt": "tool:ast.renameSymbol {\"path\":\"evals/replay-workspace/hello.txt\",\"oldName\":\"hello\",\"newName\":\"greeting\"}",
      "expectContains": "greeting"
    },
    {
      "name": "tool_ast_renameSymbol_invalid_identifier",
      "prompt": "tool:ast.renameSymbol {\"path\":\"evals/replay-workspace/hello.txt\",\"oldName\":\"hello\",\"newName\":\"123bad\"}",
      "expectContains": "Invalid identifier"
    },
    {
      "name": "tool_ast_wrapWithTryCatch",
      "prompt": "tool:ast.wrapWithTryCatch {\"path\":\"evals/replay-workspace/hello.txt\",\"insertLine\":0}",
      "expectContains": "catch"
    },
    {
      "name": "tool_ast_addTypeAnnotation",
      "prompt": "tool:ast.addTypeAnnotation {\"path\":\"evals/replay-workspace/hello.txt\",\"variableName\":\"greeting\",\"typeAnnotation\":\"string\"}",
      "expectContains": "string"
    },
    {
      "name": "tool_ast_extractFunction",
      "prompt": "tool:ast.extractFunction {\"path\":\"src/tools/defaultRegistry.ts\",\"functionName\":\"createDefaultToolRegistry\",\"newFilePath\":\"evals/replay-workspace/extracted_fn.ts\"}",
      "expectContains": "newFile"
    },
    {
      "name": "tool_deps_list",
      "prompt": "tool:deps.list {\"packageJsonPath\":\"package.json\",\"includeDev\":true}",
      "expectContains": "dependencies"
    },
    {
      "name": "tool_deps_outdated",
      "prompt": "tool:deps.outdated {\"packageJsonPath\":\"package.json\"}",
      "expectContains": "outdated"
    },
    {
      "name": "tool_deps_graph_dot",
      "prompt": "tool:deps.graph {\"format\":\"dot\",\"maxDepth\":1}",
      "expectContains": "digraph"
    },
    {
      "name": "tool_deps_conflicts",
      "prompt": "tool:deps.conflicts {\"packageJsonPath\":\"package.json\"}",
      "expectContains": "conflicts"
    },
    {
      "name": "tool_deps_why_typescript",
      "prompt": "tool:deps.why {\"packageName\":\"typescript\"}",
      "expectContains": "typescript"
    },
    {
      "name": "tool_test_parse_no_report",
      "prompt": "tool:test.parse {\"reportPath\":\"__nonexistent__/report.xml\"}",
      "expectContains": "summary"
    },
    {
      "name": "tool_test_coverage_no_report",
      "prompt": "tool:test.coverage {\"reportPath\":\"__nonexistent__/coverage.json\"}",
      "expectContains": "summary"
    }
  ]
}
